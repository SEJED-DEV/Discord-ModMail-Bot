# ── Discord Bot Token ──────────────────────────────────────────────────────
# https://discord.com/developers/applications → Your Bot → Token
DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ── Server Config ──────────────────────────────────────────────────────────
# Right-click your server → Copy Server ID  (enable Developer Mode first)
GUILD_ID=YOUR_GUILD_ID_HERE

# Right-click your staff role → Copy Role ID
STAFF_ROLE_ID=YOUR_STAFF_ROLE_ID_HERE

# Displayed fallback name (only used if STAFF_ROLE_ID is not set)
STAFF_ROLE_NAME=Your_support_team_role

# ── Channel / Category Names ──────────────────────────────────────────────
MODMAIL_CATEGORY_NAME=Cortex ModMail
LOG_CHANNEL_NAME=modmail-logs

# ── Behaviour ─────────────────────────────────────────────────────────────
# Ping the staff role in the ticket channel when a new ticket is opened
STAFF_PING_ON_OPEN=true

# Seconds between DM messages from the same user (prevents spam)
DM_COOLDOWN_SECONDS=5

# ── Auto-Close ─────────────────────────────────────────────────────────────
# Hours of inactivity before sending the user a warning
AUTO_CLOSE_HOURS=48

# Hours after the warning before the ticket is automatically closed
AUTO_CLOSE_GRACE_HOURS=24
